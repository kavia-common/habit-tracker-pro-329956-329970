# Copy to .env (already referenced as an asset in pubspec.yaml) and adjust as needed.

# Enable/disable backend sync. When disabled, the app remains local-first using Hive only.
BACKEND_SYNC_ENABLED=false

# FastAPI base URL (scheme + host + port).
# Android emulator: http://10.0.2.2:3001
# iOS simulator: http://localhost:3001
BACKEND_BASE_URL=http://10.0.2.2:3001
